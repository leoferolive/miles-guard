# --- Banco (compartilhado worker + web; também é o barramento LISTEN/NOTIFY) ---
DATABASE_URL=postgresql://nossoradar:nossoradar@localhost:5432/nossoradar

# --- Worker WhatsApp ---
# Caminho do auth state do Baileys (em prod = volume/PVC montado)
WA_SESSION_PATH=./.session
# Atraso base (ms) da reconexão com backoff exponencial
WA_RECONNECT_DELAY=5000

# --- Telegram (Alerta de Detecção) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web / API ---
PORT=3000
PUBLIC_URL=http://localhost:3000
JWT_SECRET=troque-isto-por-no-minimo-32-caracteres-aleatorios

# --- Login do dono (ADR-0007: e-mail + senha) ---
# Único e-mail aceito no login.
AUTH_EMAIL=leoferolive@gmail.com
# Hash bcrypt da senha (NUNCA a senha em texto). Em dev pode ficar vazio (usa o
# default: senha `dev`). Gere o seu com:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'SUASENHA'
AUTH_PASSWORD_HASH=
