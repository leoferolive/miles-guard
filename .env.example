# --- Banco (compartilhado worker + web; também é o barramento LISTEN/NOTIFY) ---
DATABASE_URL=postgresql://nossoradar:nossoradar@localhost:5432/nossoradar

# --- Worker WhatsApp ---
# Caminho do auth state do Baileys (em prod = volume/PVC montado)
WA_SESSION_PATH=./.session

# --- Telegram (Alerta de Detecção) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web / API ---
PORT=3000
PUBLIC_URL=http://localhost:3000
JWT_SECRET=troque-isto-por-no-minimo-32-caracteres-aleatorios

# --- Google OAuth (ADR-0005: reaproveitar credencial do nossalista) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Allowlist: SOMENTE estes e-mails podem logar (separados por vírgula)
ALLOWED_EMAILS=leoferolive@gmail.com
